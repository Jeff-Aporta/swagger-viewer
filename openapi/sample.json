{
  "openapi": "3.0.3",
  "info": {
    "title": "Swagger Viewer — demo",
    "version": "1.0.0",
    "description": "Especificación de ejemplo para el visor OpenAPI (@jeff-aporta)."
  },
  "servers": [{ "url": "https://api.example.com" }],
  "tags": [
    { "name": "Saludos", "description": "Endpoints de demostración" },
    { "name": "Auth", "description": "Autenticación de prueba" }
  ],
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/hola": {
      "get": {
        "tags": ["Saludos"],
        "summary": "Saludo simple",
        "parameters": [
          {
            "name": "nombre",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Nombre a saludar"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": { "ok": true, "mensaje": "Hola mundo" }
              }
            }
          }
        },
        "x-iss-doc-md": "## Doc interna\n\nEste endpoint es solo **demostración** del panel Doc."
      }
    },
    "/api/echo": {
      "post": {
        "tags": ["Saludos"],
        "summary": "Eco JSON",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "texto": "hola" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Eco",
            "content": {
              "application/json": {
                "example": { "eco": { "texto": "hola" } }
              }
            }
          },
          "401": { "description": "Sin JWT" }
        }
      }
    }
  }
}
