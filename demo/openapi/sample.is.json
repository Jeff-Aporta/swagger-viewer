sibles\n\n#### 200 — Eliminada correctamente\n\nEl cuerpo sigue el envelope InSoft (`encabezado` + `respuesta`). En `respuesta` viene la conversación actualizada con `itdestado: 2`.\n\n#### 401 — No autorizado\n\nFalta el header `Authorization` o el JWT no es válido. Revisa el panel superior.\n\n#### 404 — No encontrada\n\nEl `iconversacion` no existe o no pertenece al contacto del token.\n\n### Notas\n\n- No elimina mensajes en OpenAI ni el registro en `CONVERSACION_LOG`.\n- Para ver el JSON de ejemplo de cada código, usa la sección **Responses** más abajo.","responses":{"200":{"description":"Conversación eliminada (soft-delete)","content":{"application/json":{"schema":{"type":"object","properties":{"encabezado":{"type":"object","properties":{"resultado":{"type":"boolean"},"tiempo":{"type":"number"},"fhentrada":{"type":"string","format":"date-time"},"fhsalida":{"type":"string","format":"date-time"},"imensaje":{"type":"integer"},"mensaje":{"type":"string"}}},"respuesta":{"type":"object","properties":{"iconversacion":{"type":"integer","example":4821},"itercero":{"type":"string","example":"900123456"},"icontacto":{"type":"string","example":"CONT-001"},"imodulo":{"type":"string","example":"CP-IA"},"titulo":{"type":"string"},"hilo":{"type":"string"},"modelo_ia":{"type":"string"},"version_ayuda":{"type":"string"},"qtokens":{"type":"integer"},"qmensajes":{"type":"integer"},"itdestado":{"type":"integer","description":"0=abierta, 1=cerrada, 2=eliminada (soft-delete)"},"bautoriza_visualizacion":{"type":"boolean"},"fhcre":{"type":"string","format":"date-time"},"fhultact":{"type":"string","format":"date-time"}}}}},"example":{"encabezado":{"resultado":true,"tiempo":-1,"fhentrada":"2026-06-19T15:30:00.000Z","fhsalida":"2026-06-19T15:30:00.042Z"},"respuesta":{"iconversacion":4821,"itercero":"900123456","icontacto":"CONT-001","imodulo":"CP-IA","titulo":"Consulta saldos cuenta 41","hilo":"thread_abc123xyz","modelo_ia":"gpt-4o-mini","version_ayuda":"1","qtokens":1840,"qmensajes":6,"