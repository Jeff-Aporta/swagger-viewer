{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/server",
    "rootDir": "server",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts"]
}
